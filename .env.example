# AlphaBotix Trading — local / Railway environment template
# Copy to .env and fill in values. Never commit real secrets.

DATABASE_URL=sqlite:///./alphabot.db
JWT_SECRET=change-me-to-a-long-unique-random-string
ADMIN_EMAILS=admin@alphabot.dev
PLATFORM_NAME=AlphaBotix Trading
ENGINE_ENABLED=1
ENV=development

# Resend transactional email (REQUIRED in production)
RESEND_API_KEY=
EMAIL_FROM=AlphaBotix Trading <updates@alphabotixtrading.com>

# Encrypt broker API keys at rest (recommended dedicated secret, >=24 chars).
# If unset, JWT_SECRET is used as a fallback (must also be >=24 chars in prod).
KEY_ENCRYPTION_SECRET=

# Optional: force Secure cookies (auto-on behind HTTPS proxies)
SESSION_COOKIE_SECURE=0

# Comma-separated browser origins for CORS (required for cross-origin frontends)
FRONTEND_ORIGIN=

# Interactive /docs — off automatically when ENV=production / on Railway
DOCS_ENABLED=

# Admin AI disk writes — keep 0 in production (Approve can edit server files)
ADMIN_AI_WRITES=0

# Free-tier bot cap for Starter (non-admin). Default 1 bot.
# Paid tiers: Growth 5 | Pro 10 | Enterprise 25. Admins unlimited.
FREE_BOT_LIMIT=1

# Stripe Checkout + Customer Portal + webhooks (never hardcode secrets)
# Secret key (sk_live_… / sk_test_…) — either name works:
STRIPE_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
# test | live — selects Price ID dictionary used by Checkout
STRIPE_ENVIRONMENT=live
# Absolute site URL used in Checkout / Portal return URLs (no trailing slash)
PUBLIC_BASE_URL=
# Webhook endpoint to configure in Stripe Dashboard:
#   POST https://YOUR_DOMAIN/webhooks/stripe
# Events: checkout.session.completed, customer.subscription.updated,
#         customer.subscription.created, customer.subscription.deleted

# Support mailto aliases (Account → Contact Support) — one alias per plan tier
SUPPORT_MAIL_DOMAIN=alphabotservices.com
SUPPORT_MAILTO_ENTERPRISE=enterprise@alphabotservices.com
SUPPORT_MAILTO_PRO=pro@alphabotservices.com
SUPPORT_MAILTO_GROWTH=growth@alphabotservices.com
SUPPORT_MAILTO_DEFAULT=support@alphabotservices.com
SUPPORT_INBOX_ENTERPRISE=vip-support@alphabotix.com
SUPPORT_INBOX_STANDARD=standard-support@alphabotix.com
SUPPORT_INBOX_GENERAL=general-support@alphabotix.com

# Market watchlist poll size (0 = entire universe). Default in code is 40.
MARKET_WATCHLIST_LIMIT=40

# Optional: Alpaca market-data keys for the equity watchlist poller
ALPACA_DATA_KEY=
ALPACA_DATA_SECRET=

# Production / Railway checklist:
#   ENV=production
#   DATABASE_URL=postgresql://...   (not SQLite)
#   JWT_SECRET=<unique >=24 chars>
#   KEY_ENCRYPTION_SECRET=<unique >=24 chars>
#   RESEND_API_KEY=<from Resend>
#   ADMIN_EMAILS=<your email> then sign up that email first
#   Run exactly ONE replica (duplicate instances can double-trade)
#   Enable Postgres backups on Railway
